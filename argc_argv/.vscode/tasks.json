{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-c",
			"type": "shell",
			"command": "gcc",
			"args": [
				"-Wall",
				"-Werror",
				"-Wextra",
				"-pedantic",
				"-std=gnu89",
				"${file}",
				"-o",
				"${fileDirname}/${fileBasenameNoExtension}"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}